{
	"name": "frontend-v4",
	"version": "2.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "node ../../scripts/refuse-frontend-v4-dev.mjs",
		"build": "pnpm run build:staging",
		"build:production": "pnpm run build:staging",
		"build:staging": "pnpm run release:prepare-staging && node ../../scripts/refuse-live-next-build.mjs .next-staging && NEXT_DIST_DIR=.next-staging next build",
		"release:prepare-staging": "node ../../scripts/refuse-root.mjs frontend-v4 release:prepare-staging && node ../../scripts/frontend-v4-release.mjs prepare-staging",
		"release:promote-staging": "node ../../scripts/refuse-root.mjs frontend-v4 release:promote-staging && node ../../scripts/frontend-v4-release.mjs promote-staging",
		"start": "node ../../scripts/refuse-root.mjs frontend-v4 start && NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-production} next start --hostname ${FRONTEND_V4_HOST:-127.0.0.1} --port ${FRONTEND_V4_PORT:-3104}",
		"start:staging": "node ../../scripts/refuse-root.mjs frontend-v4 start:staging && NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-staging} next start --hostname ${FRONTEND_V4_HOST:-127.0.0.1} --port ${FRONTEND_V4_PORT:-3114}",
		"typecheck": "NEXT_DIST_DIR=.next-staging next typegen && tsc --noEmit"
	},
	"dependencies": {
		"3d-force-graph": "1.80.0",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"next": "16.3.0-canary.73",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"shared": "workspace:*",
		"three": "0.185.1"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/three": "0.185.0",
		"typescript": "6.0.3"
	},
	"engines": {
		"node": "26.x"
	}
}
